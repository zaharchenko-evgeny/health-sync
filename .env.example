# Public-safe example only. Copy to /opt/mcp/health-sync/.env on the VPS.

HEALTH_SYNC_DB_PATH=/data/health-sync.sqlite3
HEALTH_SYNC_DRY_RUN=true
HEALTH_SYNC_TIMEZONE=Europe/Berlin
HEALTH_SYNC_LOOKBACK_DAYS=3
PREFECT_HOME=/data/prefect

GARMIN_MCP_URL=http://127.0.0.1:8910/mcp
YAZIO_MCP_URL=http://127.0.0.1:8911/mcp
ZEPP_MCP_URL=http://127.0.0.1:8912/mcp

YAZIO_GARMIN_MEAL_TIME=21:00:00
YAZIO_GARMIN_ENTRY_NAME=Yazio daily total

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
STRAVA_ACCESS_TOKEN=
STRAVA_TOKEN_EXPIRES_AT=0
STRAVA_TOKEN_FILE=/data/strava-token.json
STRAVA_WEIGHT_THRESHOLD_KG=0.1

HEALTH_SYNC_SERVE_INTERVAL_MINUTES=180
